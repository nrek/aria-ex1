{
  "name": "aria-ex1",
  "version": "0.1.0",
  "description": "Execution-First Claude Code plugin: per-repo CODEMAP.md, cross-repo STITCH.md, complexity-tiered /distill task specs, and edit-time change enforcement (impact / alternatives / scope). Skills require ~/.claude/aria-ex1.local.md — run /setup if missing.",
  "author": {
    "name": "Mike Prasad"
  },
  "homepage": "https://github.com/nrek/aria-ex1",
  "repository": "https://github.com/nrek/aria-ex1",
  "license": "CC-BY-NC-SA-4.0",
  "keywords": [
    "codemap",
    "execution-first",
    "task-distillation",
    "full-stack",
    "hooks",
    "enforcement"
  ],
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/bin/pre-edit-check.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Glob|Grep",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/bin/pre-explore-codemap-check.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/bin/post-edit-check.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
